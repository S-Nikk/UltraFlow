{
  "name": "Ultraflow Integration",
  "version": "1.1.0",
  "description": "Brain memory system for AI coding agents - memory, context, checkpoint, token tracking",
  "type": "integration",
  "manifest_version": "1.0",
  "components": {
    "brain": {
      "type": "mcp-server",
      "enabled": true,
      "description": "Brain memory system with vault, context, and checkpoints",
      "path": "node_modules/ultraflow/lib/brain-server/server.js",
      "tools": [
        "search_memories",
        "get_memory",
        "list_memories",
        "refresh_index",
        "save_memory",
        "checkpoint",
        "load_context",
        "generateCheckpoint",
        "loadCheckpoint",
        "adjustThreshold",
        "view_dashboard",
        "get_token_summary",
        "get_task_list",
        "get_optimization_alerts",
        "generate_session_report",
        "get_agent_usage_log",
        "log_agent_dispatch",
        "get_agent_usage_summary"
      ]
    },
    "token-dashboard": {
      "type": "service",
      "enabled": true,
      "description": "Real-time token cost monitoring dashboard",
      "port": 3000,
      "auto_start": true,
      "endpoints": [
        "/api/health",
        "/api/summary",
        "/api/tasks",
        "/api/usage",
        "/api/turns",
        "/api/pricing",
        "/api/costs",
        "/api/opportunities"
      ]
    }
  },
  "hooks": {
    "session_start": true,
    "session_end": true,
    "post_tool_use": true
  },
  "configuration": {
    "memory_path": ".claude/memory",
    "config_path": ".ultraflow",
    "dashboard_url": "http://localhost:3000",
    "auto_save": true,
    "cache_ttl": 3600,
    "context_threshold": 2000,
    "max_conscious_tokens": 3000
  },
  "supported_ais": [
    "claude-code",
    "opencode",
    "codex",
    "openclaw"
  ]
}