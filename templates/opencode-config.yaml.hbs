# Ultraflow Configuration for OpenCode

version: 1.0
integration: ultraflow

# Brain memory integration
memory:
  enabled: true
  type: brain-vault
  path: .claude/memory
  auto_index: true
  cache_ttl: 3600

# Token Dashboard
token_dashboard:
  enabled: true
  port: 3000
  auto_start: true
  url: http://localhost:3000

# Code generation defaults
generation:
  model: opencode-ai
  effort_level: 2
  timeout_seconds: 300
  auto_format: true

# MCP Server
mcp:
  ultraflow-brain:
    enabled: true
    server_path: node_modules/ultraflow/lib/brain-server/server.js
    memory_path: .claude/memory

# Tools available
tools:
  - search_memories
  - get_memory
  - list_memories
  - refresh_index
  - save_memory
  - checkpoint
  - load_context
  - generateCheckpoint
  - adjustThreshold
  - loadCheckpoint
  - view_dashboard
  - get_token_summary
  - get_task_list
  - get_optimization_alerts
  - generate_session_report
  - get_agent_usage_log
  - log_agent_dispatch
  - get_agent_usage_summary

# Features
features:
  - Brain memory
  - Token dashboard
  - Session hooks
  - Agent usage logging

---
