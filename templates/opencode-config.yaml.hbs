# Ultraflow Configuration for OpenCode

version: 1.0
integration: ultraflow

# Brain memory integration
memory:
  enabled: true
  type: brain-vault
  path: .claude/memory
  auto_index: true
  cache_ttl: 3600

# Code generation defaults
generation:
  model: opencode-ai
  effort_level: 2
  timeout_seconds: 300
  auto_format: true
  include_tests: {{#if (includes features 'Brain memory')}}true{{else}}false{{/if}}

# Delegation rules
delegation:
  enabled: true
  auto_detect: true
  min_lines_for_delegation: 100
  categories:
    - code-generation
    - refactoring
    - test-writing
    - optimization

# Features
features:
{{#each features}}
  - {{this}}
{{/each}}

# Hooks
hooks:
  pre_generation: ~
  post_generation: ~
  error_handler: ~

---
# Generated by Ultraflow CLI
