{
  "mcpServers": {
    "ultraflow-brain": {
      "command": "node",
      "args": ["{{ultraflowPath}}/lib/brain-server/server.js"],
      "env": {
        "BRAIN_MEMORY_PATH": ".claude/memory",
        "DASHBOARD_URL": "http://localhost:3000"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{ultraflowPath}}/hooks/claude-code/SessionStart.js\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{ultraflowPath}}/hooks/claude-code/SessionEnd.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{ultraflowPath}}/hooks/claude-code/PostToolUse.js\""
          }
        ]
      }
    ]
  }
}