{
  "mcpServers": {
    "ultraflow-brain": {
      "command": "node",
      "args": ["{{ultraflowPath}}/lib/brain-server/server.js"],
      "env": {
        "BRAIN_MEMORY_PATH": ".claude/memory",
        "DASHBOARD_URL": "http://localhost:3000"
      }
    }
  },
  "hooks": {
    "SessionStart": {
      "command": "node",
      "args": ["{{ultraflowPath}}/hooks/claude-code/SessionStart.js"],
      "description": "Auto-load context and start dashboard"
    },
    "SessionEnd": {
      "command": "node",
      "args": ["{{ultraflowPath}}/hooks/claude-code/SessionEnd.js"],
      "description": "Save checkpoint and cleanup"
    },
    "PostToolUse": {
      "command": "node",
      "args": ["{{ultraflowPath}}/hooks/claude-code/PostToolUse.js"],
      "description": "Log agent usage"
    }
  }
}