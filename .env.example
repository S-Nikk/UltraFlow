# Orchestration Configuration

# Enable orchestration layer
ORCHESTRATION_ENABLED=true

# Message Broker Configuration
MESSAGE_BROKER_PORT=3333
MESSAGE_BROKER_HOST=localhost
MESSAGE_QUEUE_SIZE=1000
CONNECTION_TIMEOUT_MS=5000

# Agent Pool Configuration
HAIKU_POOL_SIZE=4
SONNET_POOL_SIZE=2
OPUS_POOL_SIZE=1
QUEUE_TIMEOUT_MS=300000

# Child Process Configuration
CHILD_SPAWN_ENABLED=true
MAX_CHILDREN=10
CHILD_TIMEOUT_MS=600000
CHILD_HEARTBEAT_INTERVAL=30000
CHILD_MAX_RETRIES=3

# Metrics Configuration
METRICS_ENABLED=true
METRICS_STORAGE=memory
METRICS_RETENTION_HOURS=24
METRICS_FLUSH_INTERVAL_MS=60000

# Logging Configuration
LOG_LEVEL=info
ORCHESTRATION_LOG_FILE=./logs/orchestration.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=10

# Paths
RUFLO_PATH=/c/Users/ecoec/AI/ruflo

# API Configuration
API_PORT=3334
API_HOST=localhost
